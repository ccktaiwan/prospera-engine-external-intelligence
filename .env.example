# Prospera ext-intel 環境變數範本（可進 git；真值寫進 .env，.env 已 gitignore）
# 用法：cp .env.example .env，填入真值；切勿把真 secret 提交進 git。

# Meta Ad Library（眼4 / Sensor S2）
# 取得：developers.facebook.com 建 app（免費）→ 設定 → App ID / App Secret
META_APP_ID=
META_APP_SECRET=
# 下面由 meta_token_exchange.py 自動換取並寫入（也可手動貼 App Access Token）
META_ACCESS_TOKEN=
